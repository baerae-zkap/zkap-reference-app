# Network (Base Sepolia — single fixed chain)
EXPO_PUBLIC_CHAIN_ID=84532
EXPO_PUBLIC_RPC_URL=https://sepolia.base.org

# OAuth - Google
# WEB_CLIENT_ID = ZK audience (aud) = the value used to derive the wallet address/anchor.
# It MUST match the web client used for login, otherwise an "Anchor mismatch" occurs. If
# unset, the app throws (fail-closed; see the ZK audience note below). IOS_CLIENT_ID = the
# iOS native sign-in client.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id.apps.googleusercontent.com
# (Optional) Set only when the canonical web client differs from WEB_CLIENT_ID above. Falls back to WEB_CLIENT_ID if unset.
# EXPO_PUBLIC_GOOGLE_IOS_WEB_CLIENT_ID=

# Passkey Configuration — based on your own RP domain (hosting assetlinks.json) and your own signing key.
# RP_ID is a public input of the same nature as the OAuth aud: it becomes part of the
# identity via rpIdHash at wallet creation, so once chosen it must stay fixed (changing it
# invalidates existing passkey authorization). If unset, the app throws (fail-closed; there
# is no built-in default domain — libs/wallet/webAuthnUtils.ts).
# On iOS the same RP_ID is also used in app.config.js associatedDomains (webcredentials:).
EXPO_PUBLIC_RP_ID=your-rp-domain.example.com
EXPO_PUBLIC_RP_NAME=ZKAP Reference
# (Android only) apk-key-hash = base64url(SHA-256 of your signing cert).
EXPO_PUBLIC_ORIGIN_ANDROID=android:apk-key-hash:<your-apk-key-hash>

# Signing-key credentials are handled in app.config.js (plugins/expo-signed), not in .env.
# (debug.keystore = the standard debug key, alias androiddebugkey / pw "android").

# ZK audience (aud) is not a circuit constant but a public input. Using the Google client id
# above, the app natively auto-computes the per-aud hAud and **always** builds
# ZkapProviderConfig.custom() (no built-in preset). Your own wallet address is derived, and the
# deployed verifier/circuit/proving artifacts are reused as-is. The app will not work if the
# client id is unset (fail-closed). (libs/wallet/providerConfigHelper.ts)

# ZK Proving Bundle (SDK manifest-backed release layout — CRS only)
# Circuit release artifacts are versioned independently of the SDK version (currently hosted at: release/v0.1.1-rc.1).
# Same as DEFAULT_RELEASE_BASE_URL in provingKeyManager.ts if unset.
# Note: this bundle no longer includes witness_gen.wasm (see the witness-gen channel below).
EXPO_PUBLIC_ZKAP_RELEASE_BASE_URL=https://storage.googleapis.com/zkap-static-config/release/v0.1.1-rc.1
# Optional production pin (first 16 hex chars of 3-of-3-SHA256SUMS SHA256)
# EXPO_PUBLIC_ZKAP_RELEASE_SHA_3_OF_3=

# Witness generator (independent distribution channel)
# witness_gen.wasm + witness_gen.json (sidecar: sha256 + compatible_ar1cs_blake3) are
# fetched from a dedicated channel separate from the CRS release. prove() receives them via
# witnessGenPath / witnessGenSidecarPath and verifies the sidecar sha256 + CRS
# ar1cs_blake3 compatibility (fail-closed). Same as DEFAULT_WITNESS_GEN_BASE_URL in
# provingKeyManager.ts if unset.
# witness-gen is versioned independently of the CRS (rc.1) (currently hosted at: release/v0.1.1-rc.3).
# The sidecar's compatible_ar1cs_blake3 pins compatibility with the rc.1 CRS.
EXPO_PUBLIC_ZKAP_WITNESS_GEN_BASE_URL=https://storage.googleapis.com/zkap-static-config/release/v0.1.1-rc.3
